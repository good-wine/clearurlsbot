# ClearURLs Bot - Cron Job Configuration Examples

# ============================================
# Database Backup Jobs
# ============================================

# Daily backup at 2 AM
0 2 * * * /workspaces/clearurlsbot/backup_db.sh >> /var/log/clearurlsbot/backup.log 2>&1

# Weekly backup every Sunday at 3 AM (for long-term retention)
0 3 * * 0 /workspaces/clearurlsbot/backup_db.sh sqlite:clearurls.db /backups/weekly >> /var/log/clearurlsbot/backup_weekly.log 2>&1

# Hourly backup for high-traffic instances
0 * * * * /workspaces/clearurlsbot/backup_db.sh >> /var/log/clearurlsbot/backup_hourly.log 2>&1

# ============================================
# Log Rotation
# ============================================

# Compress logs older than 7 days (daily at 4 AM)
0 4 * * * find /var/log/clearurlsbot -name "*.log" -mtime +7 -exec gzip {} \;

# Delete compressed logs older than 30 days (weekly)
0 5 * * 0 find /var/log/clearurlsbot -name "*.log.gz" -mtime +30 -delete

# ============================================
# Database Maintenance
# ============================================

# Vacuum SQLite database (optimize storage) - weekly at 4 AM
0 4 * * 1 sqlite3 /workspaces/clearurlsbot/clearurls.db "VACUUM;" >> /var/log/clearurlsbot/vacuum.log 2>&1

# Analyze tables for query optimization - daily at 5 AM
0 5 * * * sqlite3 /workspaces/clearurlsbot/clearurls.db "ANALYZE;" >> /var/log/clearurlsbot/analyze.log 2>&1

# ============================================
# Health Checks and Monitoring
# ============================================

# Check if bot process is running every 5 minutes
*/5 * * * * pgrep -f "clear_urls_bot" > /dev/null || (echo "Bot is down!" | mail -s "ClearURLs Bot Alert" admin@example.com)

# Disk space check - daily at 6 AM
0 6 * * * df -h | grep -E '(9[0-9]|100)%' && echo "Disk space critical" | mail -s "Disk Space Alert" admin@example.com

# ============================================
# Backup to Remote Storage (Optional)
# ============================================

# Upload backups to S3/MinIO daily at 3 AM
# Requires: apt-get install awscli or mc (MinIO client)
#0 3 * * * aws s3 sync /workspaces/clearurlsbot/backups s3://my-bucket/clearurlsbot-backups/ --delete

# Upload to remote server via rsync
#30 3 * * * rsync -avz /workspaces/clearurlsbot/backups/ user@backup-server:/backups/clearurlsbot/

# ============================================
# Installation Instructions
# ============================================
# 1. Copy this file: cp crontab.example /tmp/clearurls_cron
# 2. Edit with your paths: nano /tmp/clearurls_cron
# 3. Install: crontab /tmp/clearurls_cron
# 4. Verify: crontab -l
# 5. View logs: tail -f /var/log/clearurlsbot/backup.log
#
# Note: Ensure log directory exists:
# mkdir -p /var/log/clearurlsbot
# chown $(whoami):$(whoami) /var/log/clearurlsbot
